# Copy this file to .env and fill in your values
# Example:
# FOUNDRY_ENDPOINT=https://<your-resource>.services.ai.azure.com/
# FOUNDRY_API_KEY=<your-api-key>
# Classic multimodal doc flow uses the resource models endpoint:
# FOUNDRY_MODELS_ENDPOINT=https://<your-resource>.services.ai.azure.com/models

FOUNDRY_ENDPOINT=
FOUNDRY_API_KEY=
FOUNDRY_MODELS_ENDPOINT=
MODEL_DEPLOYMENT=
# Optional (Part 1): second deployment with Foundry-level guardrails enabled
MODEL_DEPLOYMENT_GUARDRAILS=
# Optional (Part 2): reasoning model deployment (falls back to MODEL_DEPLOYMENT)
REASONING_MODEL_DEPLOYMENT=
# Optional (Part 2): function-calling/web-search model deployment (falls back to MODEL_DEPLOYMENT)
FUNCTION_CALLING_MODEL_DEPLOYMENT=
# Optional (Part 3): image/text multimodal deployment (falls back to MODEL_DEPLOYMENT)
MULTIMODAL_MODEL_DEPLOYMENT=
# Optional (Part 3): audio-capable deployment (same as MULTIMODAL_MODEL_DEPLOYMENT for Phi-4)
AUDIO_MODEL_DEPLOYMENT=
